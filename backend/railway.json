{
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": [
      "**/*.php",
      "**/*.html",
      "**/*.css",
      "**/*.js",
      "Dockerfile",
      ".env"
    ]
  },
  "deploy": {
    "startCommand": "apache2-foreground",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}